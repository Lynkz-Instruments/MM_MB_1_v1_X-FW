{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "BMP Power Cycle",
			"type": "shell",
			"command": "gdb-multiarch --quiet --batch -ex 'target extended-remote /dev/ttyACM0' -ex 'monitor swd_scan' -ex 'monitor tpwr disable' -ex 'shell sleep 0.5' -ex 'monitor tpwr enable' -ex 'shell sleep 0.5'",
			"presentation": { "reveal": "silent", "close": true },
			"problemMatcher": []
		},
		{
			"type": "cmake",
			"label": "build",
			"command": "build",
			"targets": [
				"all"
			],
			"preset": "${command:cmake.activeBuildPresetName}",
			"group": "build",
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": ["relative", "/workspaces/MM_MB_1_v1_X-FW"],
                "pattern": [
                    {
                        "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    }
                ]
            },
			"detail": "CMake template build task"
		}
	]
}