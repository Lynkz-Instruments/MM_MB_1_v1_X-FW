{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32WL M4",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "bmp",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/MM_MB_1_v1_X-FW.elf",
            "gdbPath": "gdb-multiarch",
            "objdumpPath": "arm-none-eabi-objdump",
            "BMPGDBSerialPort": "/dev/ttyACM0",
            "interface": "swd",
            "targetId": 1,
            "showDevDebugOutput": "none",
            "svdFile": "${workspaceFolder}/STM32WL5x_CM4.svd",

            "postLaunchCommands": [
                "monitor erase_mass",
                "load",
                "break main",
                "set $pc = Reset_Handler",
                // "continue"
            ]
        }
    ]
}
